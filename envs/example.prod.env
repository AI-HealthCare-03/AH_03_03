# docker
DOCKER_USER=ozcodingschool
DOCKER_REPOSITORY=ai-health

# fastapi
APP_VERSION=v1.0.0
ENV=prod
SECRET_KEY=PLEASE_CHANGE_ME
COOKIE_DOMAIN=localhost
CORS_ALLOW_ORIGINS=https://your-frontend-domain.example
LOGIN_FAILURE_LIMIT=5
LOGIN_SOFT_LOCK_MINUTES=1

# phone verification
# 실제 secret 값은 운영 비밀관리 도구나 배포 환경변수에만 설정하세요.
TWILIO_ENABLED=true
TWILIO_ACCOUNT_SID=CHANGEME
TWILIO_AUTH_TOKEN=CHANGEME
TWILIO_VERIFY_SERVICE_SID=CHANGEME

# email
# 실제 secret 값은 운영 비밀관리 도구나 배포 환경변수에만 설정하세요.
EMAIL_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=AI HealthCare
SMTP_USE_TLS=true
FRONTEND_BASE_URL=https://your-frontend-domain.example

# ai-worker
AI_WORKER_VERSION=v1.0.0

# db
DB_HOST=postgres
DB_PORT=5432
DB_EXPOSE_PORT=5432
DB_USER=ozcoding
DB_PASSWORD=PLEASE_CHANGE_ME
DB_NAME=ai_health

# redis
REDIS_HOST=redis
REDIS_PORT=6379
