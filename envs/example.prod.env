# docker
DOCKER_USER=ozcodingschool
DOCKER_REPOSITORY=ai-health

# fastapi
APP_VERSION=v1.0.0
ENV=prod
SECRET_KEY=PLEASE_CHANGE_ME
COOKIE_DOMAIN=localhost
CORS_ALLOW_ORIGINS=https://your-frontend-domain.example

# ai-worker
AI_WORKER_VERSION=v1.0.0

# firebase
# Firebase Project ID
FIREBASE_PROJECT_ID=
# Path to Firebase service account JSON. Do not commit the JSON file.
# Example: /run/secrets/firebase-service-account.json
FIREBASE_CREDENTIALS_PATH=
# Firebase service account JSON string. Keep empty in example files.
FIREBASE_CREDENTIALS_JSON=

# db
DB_HOST=postgres
DB_PORT=5432
DB_EXPOSE_PORT=5432
DB_USER=ozcoding
DB_PASSWORD=PLEASE_CHANGE_ME
DB_NAME=ai_health

# redis
REDIS_HOST=redis
REDIS_PORT=6379
