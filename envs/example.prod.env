# docker
DOCKER_USER=kdu0312
DOCKER_REPOSITORY=ai-health
# HTTPS 운영 기본 설정입니다. 최초 Let's Encrypt 발급 전에는 ../nginx/prod_http.conf로 임시 전환할 수 있습니다.
NGINX_CONF=../nginx/prod_https.conf

# app/runtime
# healthladder.duckdns.org 기준 v1.1.0 수동 검증 운영 예시입니다.
# 이 파일은 bootstrap/template이며, 실제 운영 설정은 EC2의 .prod.env에만 작성하세요.
# GitHub Actions 자동배포 후 version 값은 main-<short-sha>로 갱신될 수 있습니다.
# 운영자가 반드시 교체해야 하는 값: SECRET_KEY, DB_PASSWORD, SMTP_*, provider secret.
# S3_BUCKET_NAME은 STORAGE_BACKEND=s3를 선택할 때만 필요합니다.
APP_VERSION=v1.1.0
ENV=prod
SECRET_KEY=<SET_IN_PROD>
COOKIE_DOMAIN=healthladder.duckdns.org
REFRESH_TOKEN_COOKIE_NAME=refresh_token
REFRESH_TOKEN_COOKIE_PATH=/api/v1/auth
REFRESH_TOKEN_COOKIE_SAMESITE=lax
REFRESH_TOKEN_COOKIE_SECURE=true
CORS_ALLOW_ORIGINS=https://healthladder.duckdns.org
LOGIN_FAILURE_LIMIT=5
LOGIN_SOFT_LOCK_MINUTES=1
ACCOUNT_LOCK_MINUTES=15
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_MINUTES=20160
JWT_LEEWAY=5

# email / SMTP
# 운영 메일 발송을 켜려면 EMAIL_ENABLED=true와 SMTP_* 값을 배포 환경에 설정하세요.
# 실제 secret 값은 운영 비밀관리 도구나 배포 환경변수에만 설정하세요.
EMAIL_ENABLED=true
EMAIL_VERIFICATION_DEBUG=false
PASSWORD_RESET_DEBUG=false
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USERNAME=<SET_IN_PROD>
SMTP_PASSWORD=<SET_IN_PROD>
SMTP_FROM_EMAIL=<SET_IN_PROD>
SMTP_FROM_NAME=Health Ladder
SMTP_USE_TLS=true
FRONTEND_BASE_URL=https://healthladder.duckdns.org

# storage
# MVP 운영 기준은 EC2 Docker volume 기반 local storage입니다.
# S3를 쓰는 경우에만 STORAGE_BACKEND=s3로 바꾸고 private bucket 이름을 S3_BUCKET_NAME에 넣습니다.
# AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY는 이 파일에 넣지 마세요.
STORAGE_BACKEND=local
UPLOAD_STORAGE_DIR=var/uploads
LOCAL_STORAGE_ROOT=var/storage
S3_BUCKET_NAME=
S3_REGION=ap-northeast-2
S3_PREFIX=ai-health/
S3_PRESIGNED_URL_EXPIRES_SECONDS=3600

# ai-worker
AI_WORKER_VERSION=v1.1.0

# frontend
FRONTEND_VERSION=v1.1.0
# Vite loads frontend public env from the repository root. Keep real values in deployment env/secrets.
# Same-origin Nginx serves frontend and proxies /api/ to FastAPI, so the frontend bundle uses the versioned API base path.
VITE_API_BASE_URL=/api/v1

# LLM / OpenAI
# 실제 secret 값은 운영 비밀관리 도구나 GitHub Actions Secrets에만 설정하세요.
OPENAI_API_KEY=<SET_IN_PROD>
OPENAI_MODEL=gpt-4o
CHATBOT_USE_REAL_LLM=true
RAG_RETRIEVAL_STRATEGY=hybrid_parallel
MAIN_CHATBOT_RAG_STRATEGY=hybrid_parallel
RAG_ENABLED=true
ANALYSIS_EXPLANATION_LLM_REWRITE_ENABLED=true
DIET_RECOMMENDATION_LLM_REWRITE_ENABLED=true
DIET_RECOMMENDATION_RAG_STRATEGY=keyword_first_vector_fallback
RAG_EMBEDDING_ENABLED=true
RAG_EMBEDDING_PROVIDER=openai
RAG_EMBEDDING_MODEL=text-embedding-3-small
RAG_EMBEDDING_DIMENSION=1536
RAG_EMBEDDING_BATCH_SIZE=64

# AI provider flags
# 운영 검증 기준은 GPT Vision 식단 분석 + RAG/rewrite 활성화입니다.
# secret, 비용 제한, 관측 설정이 준비된 운영 환경에서만 이 조합을 사용하세요.
DIET_GPT_VISION_ENABLED=true
DIET_GPT_VISION_MODEL=gpt-4o
DIET_VISION_PROVIDER=gpt_vision
# true일 때만 rule_based 데모 fallback을 저장합니다. 운영 기본 false에서는 실제 provider 없으면 service_unavailable입니다.
DIET_DEMO_FALLBACK_ENABLED=false
FOOD_CV_CONFIDENCE_THRESHOLD=0.75

# Public Data API - MFDS Food Nutrition DB
# 운영에서 식약처 영양성분 매칭을 켤 때 true로 전환하고 service key를 배포 secret에 설정하세요.
# 실제 service key는 이 example 파일에 넣지 않습니다.
DIET_MFDS_ENABLED=false
MFDS_SERVICE_KEY=
MFDS_SERVICE_KEY_ENCODED=
DIET_MFDS_TIMEOUT_SECONDS=5.0
DIET_MFDS_MAX_CANDIDATES=5

# 건강검진 OCR provider:
# - fallback: provider 미설정 상태. 더미 결과를 저장하지 않고 OCR job이 실패합니다.
# - gpt_vision: GPT Vision 직접 사용. OPENAI_API_KEY와 EXAM_GPT_VISION_ENABLED=true 필요.
# - auto/paddleocr: PaddleOCR dependency가 준비된 환경에서 사용. GPT Vision fallback까지 쓰려면 GPT_VISION_FALLBACK_ENABLED=true도 함께 명시하세요.
# v1.1.0 운영 검증 기준은 PaddleOCR primary + GPT Vision fallback입니다.
# PaddleOCR는 ai-worker image에만 포함하며 FastAPI image에는 무거운 OCR dependency를 넣지 않습니다.
EXAM_OCR_PROVIDER=auto
EXAM_GPT_VISION_ENABLED=true
EXAM_GPT_VISION_MODEL=gpt-4o
PADDLE_OCR_ENABLED=true

# observability / Langfuse
# Langfuse is used for trace/prompt/eval observability, not as a RAG engine.
# Do not put real keys in example env files.
# Cloud example: LANGFUSE_BASE_URL=https://jp.cloud.langfuse.com
# Self-host example: set this to the reachable self-host URL for the runtime.
# Cloud keys and self-host keys are not interchangeable.
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://jp.cloud.langfuse.com
LANGFUSE_HOST=

# auto/paddleocr 경로에서 GPT Vision fallback을 허용할 때 true로 둡니다.
GPT_VISION_FALLBACK_ENABLED=true

# PostgreSQL
# 이번 데모 운영 범위에서는 RDS를 사용하지 않고 EC2 내부 postgres 컨테이너를 사용합니다.
DB_HOST=postgres
DB_PORT=5432
DB_USER=ozcoding
DB_PASSWORD=<SET_IN_PROD>
DB_NAME=ai_health
DB_POOL_MIN_SIZE=1
DB_POOL_MAX_SIZE=5
DB_CONNECTION_POOL_MAXSIZE=
DB_COMMAND_TIMEOUT=60

# Redis
# 이번 데모 운영 범위에서는 ElastiCache를 사용하지 않고 EC2 내부 redis 컨테이너를 사용합니다.
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# scheduler
# v1.1.0 운영 검증 기준은 scheduler enabled입니다.
# 실제 알림 발송/중복 생성 QA를 마친 뒤 운영에서 유지하세요.
SCHEDULER_ENABLED=true
SCHEDULER_INTERVAL_SECONDS=60
