# docker
DOCKER_USER=ozcodingschool
DOCKER_REPOSITORY=ai-health
# HTTPS 운영 기본 설정입니다. 최초 Let's Encrypt 발급 전에는 ../nginx/prod_http.conf로 임시 전환할 수 있습니다.
NGINX_CONF=../nginx/prod_https.conf

# app/runtime
# 운영자가 반드시 교체해야 하는 값: SECRET_KEY, COOKIE_DOMAIN, CORS_ALLOW_ORIGINS, FRONTEND_BASE_URL.
APP_VERSION=v1.0.0
ENV=prod
SECRET_KEY=PLEASE_CHANGE_ME
COOKIE_DOMAIN=your-api-domain.example
REFRESH_TOKEN_COOKIE_NAME=refresh_token
REFRESH_TOKEN_COOKIE_PATH=/api/v1/auth
REFRESH_TOKEN_COOKIE_SAMESITE=lax
REFRESH_TOKEN_COOKIE_SECURE=true
CORS_ALLOW_ORIGINS=https://your-frontend-domain.example
LOGIN_FAILURE_LIMIT=5
LOGIN_SOFT_LOCK_MINUTES=1

# email / SMTP
# 운영 메일 발송을 켜려면 EMAIL_ENABLED=true와 SMTP_* 값을 배포 환경에 설정하세요.
# 실제 secret 값은 운영 비밀관리 도구나 배포 환경변수에만 설정하세요.
EMAIL_ENABLED=true
EMAIL_VERIFICATION_DEBUG=false
PASSWORD_RESET_DEBUG=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=AI HealthCare
SMTP_USE_TLS=true
FRONTEND_BASE_URL=https://your-frontend-domain.example

# storage / S3
# 운영 S3는 private bucket + IAM Role 사용을 전제로 합니다.
# AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY는 가급적 설정하지 말고 EC2 IAM Role을 사용하세요.
# S3_BUCKET_NAME은 운영자가 실제 private bucket 이름으로 교체해야 합니다.
STORAGE_BACKEND=s3
LOCAL_STORAGE_ROOT=var/storage
S3_BUCKET_NAME=your-private-bucket-name
S3_REGION=ap-northeast-2
S3_PREFIX=ai-health/prod
S3_PRESIGNED_URL_EXPIRES_SECONDS=3600

# ai-worker
AI_WORKER_VERSION=v1.0.0

# frontend / Firebase Web Push public config
FRONTEND_VERSION=v1.0.0
# Vite loads frontend public env from the repository root. Keep real values in deployment env/secrets.
# These VITE_* values are public browser config; do not add server secrets with VITE_ prefixes.
VITE_API_BASE_URL=/api/v1
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
VITE_FIREBASE_VAPID_KEY=

# Firebase Admin SDK
# FCM 서버 발송은 Firebase Admin SDK ADC를 사용합니다.
# EC2에서는 서비스 계정 파일 경로를 GOOGLE_APPLICATION_CREDENTIALS에 지정하거나, 별도 secret mount를 사용하세요.
# private_key/client_email 같은 serviceAccount 원문은 이 파일에 넣지 않습니다.
GOOGLE_APPLICATION_CREDENTIALS=

# LLM / OpenAI
# 실제 secret 값은 운영 비밀관리 도구나 GitHub Actions Secrets에만 설정하세요.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
CHATBOT_USE_REAL_LLM=false
RAG_ENABLED=false

# AI provider flags
# 운영에서 실제 provider를 켤 때는 secret, 비용 제한, 관측 설정이 준비된 뒤 true로 전환하세요.
DIET_GPT_VISION_ENABLED=false
DIET_GPT_VISION_MODEL=gpt-4o-mini
DIET_VISION_PROVIDER=rule_based
EXAM_OCR_PROVIDER=fallback
EXAM_GPT_VISION_ENABLED=false
EXAM_GPT_VISION_MODEL=gpt-4o-mini
PADDLE_OCR_ENABLED=false
MEDICATION_OCR_PROVIDER=fallback
MEDICATION_GPT_VISION_ENABLED=false
MEDICATION_GPT_VISION_MODEL=gpt-4o-mini

# observability / Langfuse
# Langfuse is used for trace/prompt/eval observability, not as a RAG engine.
# Do not put real keys in example env files.
# Cloud example: LANGFUSE_BASE_URL=https://jp.cloud.langfuse.com
# Self-host example: set this to the reachable self-host URL for the runtime.
# Cloud keys and self-host keys are not interchangeable.
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://jp.cloud.langfuse.com

# Clova OCR
# 실제 Invoke URL과 Secret Key는 운영 비밀관리 도구나 GitHub Actions Secrets에만 설정하세요.
CLOVA_OCR_API_URL=https://your-clova-ocr-invoke-url
CLOVA_OCR_SECRET_KEY=your-clova-ocr-secret-key

# checkup OCR routing
CHECKUP_OCR_PRIMARY_PROVIDER=paddle
ENABLE_CLOVA_OCR=false
GPT_VISION_FALLBACK_ENABLED=false

# PostgreSQL
# EC2 단일 호스트 compose 기준 DB_HOST=postgres입니다. 외부 RDS 사용 시 RDS endpoint로 교체하세요.
DB_HOST=postgres
DB_PORT=5432
DB_EXPOSE_PORT=5432
DB_USER=ozcoding
DB_PASSWORD=PLEASE_CHANGE_ME
DB_NAME=ai_health
DB_POOL_MIN_SIZE=1
DB_POOL_MAX_SIZE=5
DB_COMMAND_TIMEOUT=60

# Redis
# EC2 단일 호스트 compose 기준 REDIS_HOST=redis입니다. 외부 ElastiCache 사용 시 endpoint로 교체하세요.
REDIS_HOST=redis
REDIS_PORT=6379
