# docker
DOCKER_USER=ozcodingschool
DOCKER_REPOSITORY=ai-health

# fastapi
APP_VERSION=v1.0.0
ENV=local
SECRET_KEY=PLEASE_CHANGE_ME
COOKIE_DOMAIN=localhost

# ai-worker
AI_WORKER_VERSION=v1.0.0

# openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# langfuse
# JP 리전 사용 아래 base URL을 사용합니다.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://jp.cloud.langfuse.com

# clova ocr
# CLOVA OCR Invoke URL
CLOVA_OCR_API_URL=https://your-clova-ocr-invoke-url
# CLOVA OCR Secret Key
CLOVA_OCR_SECRET_KEY=your-clova-ocr-secret-key

# firebase
# Firebase Project ID
FIREBASE_PROJECT_ID=
# Path to local Firebase service account JSON. Do not commit the JSON file.
# Example: /run/secrets/firebase-service-account.json
FIREBASE_CREDENTIALS_PATH=
# Firebase service account JSON string. Keep empty in example files.
FIREBASE_CREDENTIALS_JSON=

# db
# Docker Compose 내부 컨테이너 네트워크 기준입니다.
# FastAPI를 호스트에서 직접 실행하고 DB만 Docker로 띄우면 DB_HOST=localhost로 바꾸세요.
DB_HOST=postgres
DB_PORT=5432
DB_EXPOSE_PORT=5432
DB_USER=ozcoding
DB_PASSWORD=PLEASE_CHANGE_ME
DB_NAME=ai_health

# redis
REDIS_HOST=redis
REDIS_PORT=6379
