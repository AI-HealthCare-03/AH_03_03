# docker
DOCKER_USER=ozcodingschool
DOCKER_REPOSITORY=ai-health

# fastapi
APP_VERSION=v1.0.0
ENV=local
SECRET_KEY=PLEASE_CHANGE_ME
COOKIE_DOMAIN=localhost
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000
LOGIN_FAILURE_LIMIT=5
LOGIN_SOFT_LOCK_MINUTES=1

# phone verification
# 로컬에서는 TWILIO_ENABLED=false일 때 실제 SMS를 보내지 않고 개발용 인증번호 흐름을 사용합니다.
TWILIO_ENABLED=false
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=

# email
# 로컬에서는 EMAIL_ENABLED=false일 때 실제 메일을 보내지 않고 debug_code/debug_token 응답으로 확인합니다.
EMAIL_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=AI HealthCare
SMTP_USE_TLS=true
FRONTEND_BASE_URL=http://localhost:5173

# ai-worker
AI_WORKER_VERSION=v1.0.0

# openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# langfuse
LANGFUSE_ENABLED=false
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
# Langfuse Cloud JP 리전 사용 시 아래 base URL을 참고합니다.
LANGFUSE_BASE_URL=https://jp.cloud.langfuse.com

# clova ocr
# CLOVA OCR Invoke URL
CLOVA_OCR_API_URL=https://your-clova-ocr-invoke-url
# CLOVA OCR Secret Key
CLOVA_OCR_SECRET_KEY=your-clova-ocr-secret-key

# db
# Docker Compose 내부 컨테이너 네트워크 기준입니다.
# FastAPI를 호스트에서 직접 실행하고 DB만 Docker로 띄우면 DB_HOST=localhost로 바꾸세요.
DB_HOST=postgres
DB_PORT=5432
DB_EXPOSE_PORT=5432
DB_USER=ozcoding
DB_PASSWORD=PLEASE_CHANGE_ME
DB_NAME=ai_health

# redis
REDIS_HOST=redis
REDIS_PORT=6379
