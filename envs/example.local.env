# docker
DOCKER_USER=ozcodingschool
DOCKER_REPOSITORY=ai-health

# fastapi
APP_VERSION=v1.0.0
SECRET_KEY=oz-codingschool-AI-health260127!@
COOKIE_DOMAIN=localhost

# ai-worker
AI_WORKER_VERSION=v1.0.0

# openai
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# langfuse
# JP 리전 사용 아래 base URL을 사용합니다.
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_BASE_URL=https://jp.cloud.langfuse.com

# clova ocr
# CLOVA OCR Invoke URL
CLOVA_OCR_API_URL=https://your-clova-ocr-invoke-url
# CLOVA OCR Secret Key
CLOVA_OCR_SECRET_KEY=your-clova-ocr-secret-key

# firebase
# Firebase Project ID
FIREBASE_PROJECT_ID=
# Path to local Firebase service account JSON. Do not commit the JSON file.
FIREBASE_CREDENTIALS_PATH=
# Firebase service account JSON string. Keep empty in example files.
FIREBASE_CREDENTIALS_JSON=

# db
# Docker Compose 내부에서 실행할 때는 DB_HOST=postgres를 사용하세요.
# FastAPI를 로컬에서 직접 실행하고 DB만 Docker로 띄우면 DB_HOST=localhost를 사용하세요.
DB_HOST=localhost
DB_PORT=5432
DB_EXPOSE_PORT=5432
DB_USER=ozcoding
DB_PASSWORD=pw1234
DB_NAME=ai_health
