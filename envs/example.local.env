# docker
DOCKER_USER=ozcodingschool
DOCKER_REPOSITORY=ai-health

# fastapi
APP_VERSION=v1.0.0
ENV=local
SECRET_KEY=PLEASE_CHANGE_ME
COOKIE_DOMAIN=localhost
REFRESH_TOKEN_COOKIE_NAME=refresh_token
REFRESH_TOKEN_COOKIE_PATH=/api/v1/auth
REFRESH_TOKEN_COOKIE_SAMESITE=lax
REFRESH_TOKEN_COOKIE_SECURE=false
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000
LOGIN_FAILURE_LIMIT=5
LOGIN_SOFT_LOCK_MINUTES=1

# email
# лЎңм»¬ к°ңл°ң нҺёмқҳмғҒ EMAIL_VERIFICATION_DEBUG=trueлҘј мӮ¬мҡ©н•  мҲҳ мһҲмҠөлӢҲлӢӨ.
# мӢӨм ң мӢңм—°/м„ңл№„мҠӨ н…ҢмҠӨнҠём—җм„ңлҠ” мқёмҰқмҪ”л“ңк°Җ нҷ”л©ҙ/APIм—җ л…ём¶ңлҗҳм§Җ м•ҠлҸ„лЎқ EMAIL_VERIFICATION_DEBUG=falseлҘј к¶ҢмһҘн•©лӢҲлӢӨ.
# мҡҙмҳҒ/prodм—җм„ңлҠ” EMAIL_VERIFICATION_DEBUG=false, PASSWORD_RESET_DEBUG=falseлҘј мң м§Җн•ҳм„ёмҡ”.
# Brevo SMTP мӢӨл°ңмҶЎ н…ҢмҠӨнҠёк°Җ н•„мҡ”н•ҳл©ҙ EMAIL_ENABLED=trueлЎң л°”кҫёкі  м•„лһҳ SMTP_* к°’мқ„ лЎңм»¬ .envм—җл§Ң мұ„мӣҒлӢҲлӢӨ.
# мҳҲ: SMTP_HOST=smtp-relay.brevo.com, SMTP_PORT=587, SMTP_USE_TLS=true
# мӢӨм ң SMTP_USERNAME/SMTP_PASSWORD к°’мқҖ мқҙ мҳҲмӢң нҢҢмқјм—җ м ҲлҢҖ л„Јм§Җ м•ҠмҠөлӢҲлӢӨ.
EMAIL_ENABLED=false
EMAIL_VERIFICATION_DEBUG=true
PASSWORD_RESET_DEBUG=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=AI HealthCare
SMTP_USE_TLS=true
FRONTEND_BASE_URL=http://localhost:8080

# storage
# кё°ліё лЎңм»¬ к°ңл°ңмқҖ м»Ён…Ңмқҙл„Ҳ/нҳёмҠӨнҠёмқҳ private local storageлҘј мӮ¬мҡ©н•©лӢҲлӢӨ.
# docker-compose.dev.ymlмқҖ /app/var/storageм—җ named volumeмқ„ л¶ҷмһ…лӢҲлӢӨ.
# S3 мҡҙмҳҒмқҖ IAM Role кё°л°ҳмқ„ м „м ңлЎң н•ҳл©°, AWS access key/secretмқҖ мқҙ нҢҢмқјм—җ л„Јм§Җ м•ҠмҠөлӢҲлӢӨ.
STORAGE_BACKEND=local
LOCAL_STORAGE_ROOT=var/storage
S3_BUCKET_NAME=
S3_REGION=ap-northeast-2
S3_PREFIX=ai-health/dev
S3_PRESIGNED_URL_EXPIRES_SECONDS=3600

# ai-worker
AI_WORKER_VERSION=v1.0.0

# frontend
FRONTEND_VERSION=v1.0.0
NGINX_HTTP_PORT=8080
# Vite loads frontend public env from the repository root. Keep real values in local .env only.
# These VITE_* values are public browser config; do not add server secrets with VITE_ prefixes.
VITE_API_BASE_URL=/api/v1
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
# Firebase Consoleмқҳ Web Push certificatesм—җм„ң л°ңкёүн•ң public VAPID keyлҘј лЎңм»¬ .envм—җл§Ң мұ„мҡ°м„ёмҡ”.
VITE_FIREBASE_VAPID_KEY=

# openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
CHATBOT_USE_REAL_LLM=false
RAG_ENABLED=false

# AI provider flags are off by default. Enable only for explicit provider smoke tests.
DIET_GPT_VISION_ENABLED=false
DIET_GPT_VISION_MODEL=gpt-4o
DIET_VISION_PROVIDER=rule_based
EXAM_OCR_PROVIDER=auto
EXAM_GPT_VISION_ENABLED=false
EXAM_GPT_VISION_MODEL=gpt-4o
PADDLE_OCR_ENABLED=false
MEDICATION_OCR_PROVIDER=fallback
MEDICATION_GPT_VISION_ENABLED=false
MEDICATION_GPT_VISION_MODEL=gpt-4o

# langfuse
# Langfuse is used for trace/prompt/eval observability, not as a RAG engine.
# Do not put real keys in example env files.
# Cloud example: LANGFUSE_BASE_URL=https://jp.cloud.langfuse.com
# Self-host, FastAPI on host: LANGFUSE_BASE_URL=http://localhost:3000
# Self-host, FastAPI in Docker:
# - use http://host.docker.internal:3000 when Langfuse is exposed on the host
# - use http://langfuse-web:3000 only when FastAPI joins the same Docker network
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://jp.cloud.langfuse.com

# clova ocr
# CLOVA OCR Invoke URL
CLOVA_OCR_API_URL=
# CLOVA OCR Secret Key
CLOVA_OCR_SECRET_KEY=

GPT_VISION_FALLBACK_ENABLED=false

# db
# Docker Compose лӮҙл¶Җ м»Ён…Ңмқҙл„Ҳ л„ӨнҠёмӣҢнҒ¬ кё°мӨҖмһ…лӢҲлӢӨ.
# FastAPIлҘј нҳёмҠӨнҠём—җм„ң м§Ғм ‘ мӢӨн–үн•ҳкі  DBл§Ң DockerлЎң лқ„мҡ°л©ҙ DB_HOST=localhostлЎң л°”кҫём„ёмҡ”.
DB_HOST=postgres
DB_PORT=5432
DB_EXPOSE_PORT=5432
DB_USER=ozcoding
DB_PASSWORD=pw1234
DB_NAME=ai_health
DB_POOL_MIN_SIZE=1
DB_POOL_MAX_SIZE=5
DB_COMMAND_TIMEOUT=60

# redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_EXPOSE_PORT=6379

# scheduler
# лЎңм»¬ к°ңл°ңм—җм„ңлҠ” кё°ліём ҒмңјлЎң мһҗлҸҷ м•ҢлҰј л°ңмҶЎ лЈЁн”„лҘј лҒ•лӢҲлӢӨ.
SCHEDULER_ENABLED=false
SCHEDULER_INTERVAL_SECONDS=60
