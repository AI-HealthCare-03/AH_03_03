// AI Healthcare MVP ERD
//
// 범위:
// - MVP는 풀서비스 1차 범위를 기준으로 하며, 소셜 로그인과 웨어러블 연동만 제외한다.
// - AUTH / USER
// - MAIN / MYPAGE
// - HEALTH
// - EXAM / OCR
// - ANALYSIS + SHAP / ML inference
// - CHALLENGE
// - RAG 공식 문서/청크 메타데이터 관리
// - DASHBOARD 조회/집계
// - NOTIFICATION / reminder_schedules / notification_logs
// - SETTINGS
// - QNA / FAQ
// - DIET 기록/분석
// - MEDICATION/SUPPLEMENT
// - LLM 생성 로그
// - FAMILY 1차 DB/API
// - ADMIN / 운영 모니터링 / 시스템 로그 / 민감정보 접근 로그
//
// 제외:
// - WEARABLE 연동
// - 소셜 로그인
//
// MVP 범위 안의 후속 구현 단계:
// - SMS/Kakao 알림 provider
// - pgvector / RAG 검색 고도화

Project ai_health_mvp {
  database_type: "PostgreSQL"
  Note: "FastAPI + AI Worker MVP schema. MVP는 풀서비스 1차 기준이며 소셜 로그인과 웨어러블 연동만 제외한다. Dashboard와 MyPage는 별도 테이블 없이 관련 테이블을 조회/집계한다."
}

Enum gender {
  MALE
  FEMALE
}

Enum async_job_status {
  PENDING
  PROCESSING
  SUCCESS
  FAILED
}

Enum analysis_type {
  DIABETES
  OBESITY
  DYSLIPIDEMIA
  HYPERTENSION
}

Enum analysis_mode {
  BASIC
  PRECISION
}

Enum ocr_status {
  PENDING
  PROCESSING
  SUCCESS
  FAILED
  CONFIRMED
}

Enum risk_level {
  LOW
  MEDIUM
  HIGH
}

Enum factor_direction {
  POSITIVE
  NEGATIVE
  NEUTRAL
}

Enum challenge_category {
  EXERCISE
  DIET
  SLEEP
  MEDICATION
  WATER
  BLOOD_PRESSURE
  BLOOD_GLUCOSE
  WEIGHT
  HABIT
}

Enum challenge_status {
  ACTIVE
  INACTIVE
}

Enum user_challenge_status {
  JOINED
  COMPLETED
  CANCELED
}

Enum rag_disease_type {
  DIABETES
  OBESITY
  DYSLIPIDEMIA
  COMMON
}

Enum family_status {
  ACTIVE
  REMOVED
}

Enum family_relation_type {
  SELF
  FATHER
  MOTHER
  SPOUSE
  CHILD
  SIBLING
  GRANDPARENT
  OTHER
}

Enum family_member_role {
  OWNER
  MEMBER
  GUARDIAN
  DEPENDENT
}

Enum family_member_status {
  ACTIVE
  INVITED
  PENDING_UNREGISTERED
  REMOVED
}

Enum family_invite_status {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
  CANCELED
}

Table users {
  id bigint [pk, increment]
  login_id varchar(40) [unique]
  email varchar(40) [not null]
  hashed_password varchar(255) [not null]
  name varchar(20) [not null]
  nickname varchar(30)
  gender gender [not null]
  birthday date [not null]
  phone_number varchar(11)
  address varchar(255)
  profile_image_url varchar(500)
  role varchar(20) [not null, default: 'USER']
  is_active boolean [not null, default: true]
  is_admin boolean [not null, default: false]
  last_login_at timestamptz
  failed_login_count int [not null, default: 0]
  locked_until timestamptz
  deactivated_at timestamptz
  email_verified_at timestamptz
  privacy_consent_agreed_at timestamptz
  privacy_consent_version varchar(30)
  created_at timestamptz [not null]
  updated_at timestamptz [not null]

  Note: "AUTH / USER 기준 테이블. phone_number는 선택 입력이므로 nullable이다. privacy_consent_*는 신규 회원가입 시 개인정보 수집·이용 동의 시각/버전을 기록한다. role 값은 USER, MONITOR, OPERATOR, ADMIN, SUPER_ADMIN을 사용한다. Firebase Auth/소셜 로그인 전용 컬럼은 제거했다. user_fcm_tokens는 과거 브라우저 Push 설계 흔적이며 MVP에서는 사용하지 않는다. 권한 판단은 role 기준이며 is_admin은 legacy 호환 필드로 유지한다. 로그인 시각 표준은 last_login_at이다."
}

Table families {
  id bigint [pk, increment]
  name varchar(100) [not null]
  owner_user_id bigint [not null, ref: > users.id]
  status family_status [not null, default: 'ACTIVE']
  created_at timestamptz [not null]
  updated_at timestamptz [not null]

  indexes {
    (owner_user_id)
    (status)
  }

  Note: "가족 그룹. 생성자가 OWNER 구성원으로 등록된다. 삭제 API는 status=REMOVED soft remove로 처리한다."
}

Table family_members {
  id bigint [pk, increment]
  family_id bigint [not null, ref: > families.id]
  user_id bigint [ref: > users.id]
  display_name varchar(100) [not null]
  phone_number varchar(30)
  email varchar(255)
  relation_type family_relation_type [not null]
  member_role family_member_role [not null, default: 'MEMBER']
  status family_member_status [not null, default: 'ACTIVE']
  is_registered boolean [not null, default: true]
  created_at timestamptz [not null]
  updated_at timestamptz [not null]

  indexes {
    (family_id)
    (user_id)
    (family_id, user_id)
    (family_id, status)
    (email)
    (phone_number)
  }

  Note: "가족 구성원. 미가입 가족은 user_id=null, is_registered=false, status=PENDING_UNREGISTERED로 저장한다."
}

Table family_invites {
  id bigint [pk, increment]
  family_id bigint [not null, ref: > families.id]
  inviter_user_id bigint [not null, ref: > users.id]
  invitee_user_id bigint [ref: > users.id]
  invitee_email varchar(255)
  invitee_phone varchar(30)
  code_hash varchar(128) [not null, unique]
  relation_type family_relation_type [not null]
  member_role family_member_role [not null, default: 'MEMBER']
  expires_at timestamptz [not null]
  used_at timestamptz
  status family_invite_status [not null, default: 'PENDING']
  created_at timestamptz [not null]

  indexes {
    (family_id)
    (inviter_user_id)
    (invitee_user_id)
    (invitee_email)
    (invitee_phone)
    (status)
    (expires_at)
  }

  Note: "가족 초대. 초대 코드 원문은 저장하지 않고 code_hash만 저장한다. 원문 코드는 생성 직후 1회만 응답한다."
}

Table family_share_settings {
  id bigint [pk, increment]
  family_id bigint [not null, ref: > families.id]
  owner_user_id bigint [not null, ref: > users.id]
  viewer_user_id bigint [not null, ref: > users.id]
  share_health_records boolean [not null, default: false]
  share_analysis_results boolean [not null, default: false]
  share_diet_records boolean [not null, default: false]
  share_medications boolean [not null, default: false]
  share_challenges boolean [not null, default: false]
  share_exam_reports boolean [not null, default: false]
  share_challenge_status boolean [not null, default: false]
  share_medication_status boolean [not null, default: false]
  share_diet_status boolean [not null, default: false]
  share_health_report_summary boolean [not null, default: false]
  share_raw_health_values boolean [not null, default: false]
  share_ocr_original boolean [not null, default: false]
  receive_analysis_alerts boolean [not null, default: false]
  receive_abnormal_value_alerts boolean [not null, default: false]
  receive_medication_alerts boolean [not null, default: false]
  created_at timestamptz [not null]
  updated_at timestamptz [not null]

  indexes {
    (family_id)
    (owner_user_id)
    (viewer_user_id)
    (family_id, owner_user_id, viewer_user_id)
  }

  Note: "가족 공유 권한. 기본값은 모두 false이며 가족 연결만으로 자동 공유하지 않는다. 행동 기반 상태 공유와 원본/민감값 공유 권한을 분리한다."
}

Table family_notification_settings {
  id bigint [pk, increment]
  owner_user_id bigint [not null, ref: > users.id]
  family_user_id bigint [not null, ref: > users.id]
  notify_challenge_missed boolean [not null, default: false]
  notify_challenge_completed boolean [not null, default: false]
  notify_medication_missed boolean [not null, default: false]
  notify_diet_missed boolean [not null, default: false]
  notify_report_updated boolean [not null, default: false]
  channel_in_app boolean [not null, default: true]
  channel_push boolean [not null, default: false]
  quiet_hours_start time
  quiet_hours_end time
  created_at timestamptz [not null]
  updated_at timestamptz [not null]

  indexes {
    (owner_user_id)
    (family_user_id)
    (owner_user_id, family_user_id) [unique]
  }

  Note: "가족 알림 수신 설정. owner_user가 공유를 허용하고 family_user가 수신을 허용한 항목만 내부 알림 대상으로 삼는다."
}

Table health_records {
  id bigint [pk, increment]
  user_id bigint [not null, ref: > users.id]
  height_cm decimal(5,2)
  weight_kg decimal(5,2)
  waist_cm decimal(5,2)
  bmi decimal(5,2)
  systolic_bp int
  diastolic_bp int
  fasting_glucose int
  hba1c decimal(4,2)
  total_cholesterol int
  ldl_cholesterol int
  hdl_cholesterol int
  triglyceride int
  has_diabetes boolean
  has_obesity boolean
  has_dyslipidemia boolean
  has_hypertension boolean
  occupation_code varchar(30)
  family_htn varchar(10)
  family_dm varchar(10)
  family_dyslipidemia varchar(10)
  smoking_status varchar(20)
  drinking_frequency varchar(30)
  drinking_amount varchar(30)
  walking_days_per_week int
  strength_days_per_week int
  sleep_hours decimal(4,2)
  measured_at timestamptz [not null]
  created_at timestamptz [not null]
  updated_at timestamptz [not null]

  indexes {
    (user_id, measured_at)
  }

  Note: "사용자의 건강정보 입력 이력. x1 기본 분석 입력은 직업군/질병별 가족력/흡연/음주/걷기/근력운동을 포함하며, BMI는 신장/체중 기반 자동 계산값으로 저장한다. 교육수준/소득수준은 기본 필수 입력에서 제외한다."
}

Table exam_reports {
  id bigint [pk, increment]
  user_id bigint [not null, ref: > users.id]
  original_filename varchar(255) [not null]
  file_path varchar(500) [not null]
  exam_date date
  ocr_status ocr_status [not null, default: 'PENDING']
  is_confirmed boolean [not null, default: false]
  uploaded_at timestamptz [not null]
  confirmed_at timestamptz
  created_at timestamptz [not null]
  updated_at timestamptz [not null]

  indexes {
    (user_id, uploaded_at)
    (user_id, exam_date)
    (ocr_status)
  }

  Note: "건강검진표 업로드 파일과 OCR 처리 상태를 관리한다. file_path는 storage backend local/S3의 private object key 또는 legacy local path를 저장한다."
}

Table exam_measurements {
  id bigint [pk, increment]
  exam_report_id bigint [not null, ref: > exam_reports.id]
  measurement_key varchar(100) [not null]
  measurement_name varchar(100) [not null]
  value varchar(100)
  unit varchar(30)
  ocr_confidence decimal(5,4)
  is_user_confirmed boolean [not null, default: false]
  created_at timestamptz [not null]
  updated_at timestamptz [not null]

  indexes {
    (exam_report_id)
    (measurement_key)
  }

  Note: "OCR로 추출된 검진 수치 원본. 사용자 확인 전까지 value는 문자열로 보관한다."
}

Table async_jobs {
  id bigint [pk, increment]
  job_type varchar(50) [not null]
  status async_job_status [not null, default: 'PENDING']
  request_payload jsonb
  result_payload jsonb
  error_message text
  stream_id varchar(100)
  created_at timestamptz [not null]
  updated_at timestamptz [not null]
  started_at timestamptz
  finished_at timestamptz

  indexes {
    (job_type, status)
    (status, created_at)
    (stream_id)
  }

  Note: "Backend가 생성하고 Redis Stream worker가 처리 상태를 갱신하는 비동기 작업 테이블. user_id/resource_id/stream/max_attempts 등 Redis 표준 job payload 메타는 request_payload 또는 stream message에 보관하며 DB 컬럼으로 직접 분리하지 않는다."
}

Table analysis_results {
  id bigint [pk, increment]
  user_id bigint [not null, ref: > users.id]
  health_record_id bigint [not null, ref: > health_records.id]
  async_job_id bigint [note: "Nullable BIGINT. 현재 analysis.run async job은 작업 상태를 async_jobs에 저장하고, 분석 결과는 analysis_results에 저장한다. DB FK는 아직 연결하지 않는다."]
  analysis_type analysis_type [not null]
  analysis_mode analysis_mode [not null, default: 'BASIC', note: "BASIC=x1 기본정보 기반, PRECISION=x1+x2 검진/혈액검사 수치 기반"]
  risk_score decimal(6,5) [not null]
  risk_level risk_level [not null]
  summary varchar(255)
  model_name varchar(100)
  model_version varchar(50)
  analyzed_at timestamptz [not null]
  created_at timestamptz [not null]
  updated_at timestamptz [not null]

  indexes {
    (user_id, analyzed_at)
    (health_record_id, analysis_type)
  }

  Note: "당뇨/비만/이상지질혈증/고혈압 위험도 분석 최종 결과. 긴 분석 실행은 analysis.run async worker가 담당하며 /analysis/run 동기 실행 경로는 410 Gone으로 막는다."
}

Table analysis_result_factors {
  id bigint [pk, increment]
  analysis_result_id bigint [not null, ref: > analysis_results.id]
  factor_key varchar(100) [not null]
  factor_name varchar(100) [not null]
  factor_value varchar(100)
  contribution_score decimal(10,6)
  direction factor_direction [not null]
  display_order int [not null, default: 0]
  created_at timestamptz [not null]

  indexes {
    (analysis_result_id, display_order)
  }

  Note: "SHAP 또는 feature contribution 기반 주요 위험요인. factor_value는 float가 아니라 varchar로 유지한다."
}

Table analysis_snapshots {
  id bigint [pk, increment]
  analysis_result_id bigint [not null, ref: > analysis_results.id]
  input_payload jsonb [not null]
  output_payload jsonb [not null]
  shap_payload jsonb
  model_payload jsonb
  created_at timestamptz [not null]

  Note: "분석 재현과 디버깅을 위한 입력/출력/SHAP 원본 스냅샷."
}

Table challenges {
  id bigint [pk, increment]
  title varchar(100) [not null]
  description text
  category challenge_category [not null]
  challenge_type varchar(10) [not null, default: 'GENERAL']
  target_disease varchar(20) [not null, default: 'GENERAL']
  difficulty varchar(10) [not null, default: 'NORMAL']
  target_metric varchar(100)
  target_value varchar(100)
  caution_message text
  contraindication_message text
  duration_days int [not null]
  status challenge_status [not null, default: 'ACTIVE']
  created_at timestamptz [not null]
  updated_at timestamptz [not null]

  indexes {
    (category, status)
    (challenge_type, target_disease, status)
  }

  Note: "팀 챌린지 마스터 데이터. SPECIAL/COMMON/GENERAL 분류와 질환군 대상, 주의/금기 문구를 포함한다."
}

Table user_challenges {
  id bigint [pk, increment]
  user_id bigint [not null, ref: > users.id]
  challenge_id bigint [not null, ref: > challenges.id]
  status user_challenge_status [not null, default: 'JOINED']
  started_at timestamptz [not null]
  expected_done_at timestamptz
  completed_at timestamptz
  canceled_at timestamptz
  created_at timestamptz [not null]
  updated_at timestamptz [not null]

  indexes {
    (user_id, status)
    (challenge_id)
  }

  Note: "사용자 챌린지 참여/완료 상태. started_at은 수행 시작 시각, expected_done_at은 완료 예정 시각, completed_at은 최종 완료 시각이다."
}

Table challenge_logs {
  id bigint [pk, increment]
  user_challenge_id bigint [not null, ref: > user_challenges.id]
  log_date date [not null]
  is_completed boolean [not null, default: false]
  completed_at timestamptz
  memo varchar(255)
  created_at timestamptz [not null]
  updated_at timestamptz [not null]

  indexes {
    (user_challenge_id, log_date)
  }

  Note: "사용자 챌린지 일별 수행 기록. 달력 완료 표시는 해당 날짜의 completed_count/total_count 기준이며 completed_at이 실제 완료 시각이다."
}

Table challenge_recommendations {
  id bigint [pk, increment]
  user_id bigint [not null, ref: > users.id]
  analysis_result_id bigint [not null, ref: > analysis_results.id]
  challenge_id bigint [not null, ref: > challenges.id]
  reason text
  priority int
  is_selected boolean [not null, default: false]
  created_at timestamptz [not null]
  updated_at timestamptz [not null]

  indexes {
    (user_id)
    (analysis_result_id)
    (challenge_id)
    (user_id, is_selected)
  }

  Note: "분석 결과와 주요 위험요인 기반 추천 챌린지."
}

Table rag_sources {
  id bigint [pk, increment]
  name varchar(100) [not null]
  organization varchar(100)
  source_type varchar(30) [not null]
  base_url varchar(500)
  description text
  is_active boolean [not null, default: true]
  created_at timestamptz [not null]
  updated_at timestamptz [not null]

  Note: "RAG 공식 근거 문서 출처 관리. pgvector embedding 컬럼은 후속 PR에서 추가한다."
}

Table rag_documents {
  id bigint [pk, increment]
  source_id bigint [not null, ref: > rag_sources.id]
  title varchar(255) [not null]
  disease_type rag_disease_type [not null]
  document_url varchar(500)
  published_at date
  fetched_at timestamptz
  version varchar(50)
  is_active boolean [not null, default: true]
  created_at timestamptz [not null]
  updated_at timestamptz [not null]

  indexes {
    (source_id)
    (disease_type, is_active)
  }

  Note: "RAG 공식 문서 메타데이터. 문서 원문/청크 검색 API는 이번 PR 범위에서 제외한다."
}

Table rag_chunks {
  id bigint [pk, increment]
  document_id bigint [not null, ref: > rag_documents.id]
  chunk_index int [not null]
  section_title varchar(255)
  content text [not null]
  disease_type rag_disease_type [not null]
  keywords text
  embedding_model varchar(100)
  created_at timestamptz [not null]
  updated_at timestamptz [not null]

  indexes {
    (document_id, chunk_index)
    (disease_type)
  }

  Note: "RAG 문서 chunk 메타데이터와 텍스트 본문. pgvector embedding 값은 아직 저장하지 않는다."
}

Table rag_retrieval_logs {
  id bigint [pk, increment]
  user_id bigint [ref: > users.id]
  analysis_result_id bigint [ref: > analysis_results.id]
  query_text text [not null]
  disease_type rag_disease_type
  retrieved_chunk_ids jsonb
  top_k int
  created_at timestamptz [not null]

  indexes {
    (user_id, created_at)
    (analysis_result_id)
  }

  Note: "향후 RAG 검색 결과 추적용 로그. 실제 검색 로직과 vector search는 이번 PR 범위에서 제외한다."
}

Table notifications {
  id bigint [pk, increment]
  user_id bigint [not null, ref: > users.id]
  notification_type varchar(30) [not null]
  title varchar(100) [not null]
  message text [not null]
  is_read boolean [not null, default: false]
  related_type varchar(50)
  related_id bigint
  read_at timestamptz
  created_at timestamptz [not null]
  updated_at timestamptz [not null]

  indexes {
    (user_id)
    (user_id, is_read)
    (notification_type)
  }

  Note: "사용자 화면에 표시되는 알림 inbox. 발송 예약과 발송 이력은 reminder_schedules/notification_logs에서 분리 관리한다."
}

Table user_fcm_tokens {
  id bigint [pk, increment]
  user_id bigint [not null, ref: > users.id]
  token varchar(512) [not null, unique]
  platform varchar(20) [not null, note: "web/android/ios"]
  device_id varchar(128)
  user_agent varchar(500)
  is_active boolean [not null, default: true]
  last_seen_at timestamptz [not null]
  revoked_at timestamptz
  created_at timestamptz [not null]
  updated_at timestamptz [not null]

  indexes {
    (user_id)
    (user_id, is_active)
    (platform)
    (last_seen_at)
  }

  Note: "과거 브라우저 Push registration token 테이블. DB 호환을 위해 남아 있으나 MVP에서는 사용하지 않는다."
}

Table reminder_schedules {
  id bigint [pk, increment]
  user_id bigint [not null, ref: > users.id]
  reminder_type varchar(30) [not null, note: "MEDICATION/CHALLENGE/HEALTH_RECORD/FAMILY_ALERT/SYSTEM"]
  channel varchar(20) [not null, default: "IN_APP", note: "IN_APP/EMAIL/SMS/PUSH/KAKAO"]
  title varchar(100) [not null]
  message text [not null]
  related_type varchar(50)
  related_id bigint
  schedule_time varchar(8)
  cron_expression varchar(100)
  timezone varchar(50) [not null, default: "Asia/Seoul"]
  is_active boolean [not null, default: true]
  last_triggered_at timestamptz
  next_trigger_at timestamptz
  created_at timestamptz [not null]
  updated_at timestamptz [not null]

  indexes {
    (user_id)
    (user_id, is_active)
    (reminder_type)
    (channel)
    (next_trigger_at)
  }

  Note: "복약/챌린지/건강기록/가족/시스템 알림 예약 설정. ai-worker scheduler가 next_trigger_at 기준으로 내부 알림을 만든다. 브라우저 Push 발송은 MVP 범위에서 제외한다."
}

Table notification_logs {
  id bigint [pk, increment]
  user_id bigint [not null, ref: > users.id]
  notification_id bigint [ref: > notifications.id]
  reminder_schedule_id bigint [ref: > reminder_schedules.id]
  notification_type varchar(30) [not null]
  channel varchar(20) [not null, default: "IN_APP"]
  title varchar(100) [not null]
  message_summary varchar(255)
  related_type varchar(50)
  related_id bigint
  status varchar(20) [not null, default: "PENDING", note: "PENDING/SENT/FAILED/SKIPPED/CANCELED"]
  provider varchar(50)
  provider_message_id varchar(120)
  error_code varchar(50)
  error_message varchar(255)
  sent_at timestamptz
  failed_at timestamptz
  created_at timestamptz [not null]

  indexes {
    (user_id)
    (notification_id)
    (reminder_schedule_id)
    (status)
    (channel)
    (created_at)
  }

  Note: "알림 발송 시도/성공/실패 이력. 민감 건강 수치 원문, 인증코드, 토큰, 비밀번호는 저장하지 않는다."
}

Table user_settings {
  id bigint [pk, increment]
  user_id bigint [not null, unique, ref: > users.id]
  notification_enabled boolean [not null, default: true]
  challenge_reminder_enabled boolean [not null, default: true]
  challenge_reminder_time time
  medication_reminder_enabled boolean [not null, default: true]
  diet_reminder_enabled boolean [not null, default: false]
  marketing_agreed boolean [not null, default: false]
  sensitive_data_agreed boolean [not null, default: false]
  created_at timestamptz [not null]
  updated_at timestamptz [not null]

  Note: "사용자별 알림 설정. 개인정보/민감정보/마케팅 동의 이력의 기준은 user_consents이며, 이 테이블의 동의성 필드는 legacy/정리 후보로 남아 있다."
}

Table faqs {
  id bigint [pk, increment]
  category varchar(50) [not null]
  question varchar(255) [not null]
  answer text [not null]
  display_order int [not null, default: 0]
  is_active boolean [not null, default: true]
  created_at timestamptz [not null]
  updated_at timestamptz [not null]

  indexes {
    (category)
    (is_active, display_order)
  }

  Note: "FAQ 최소 기능. 관리자 페이지는 이번 범위에서 제외한다."
}

Table inquiries {
  id bigint [pk, increment]
  user_id bigint [not null, ref: > users.id]
  category varchar(50) [not null]
  title varchar(255) [not null]
  content text [not null]
  status varchar(30) [not null, default: 'PENDING']
  answer text
  answered_at timestamptz
  created_at timestamptz [not null]
  updated_at timestamptz [not null]

  indexes {
    (user_id)
    (status)
    (category)
  }

  Note: "사용자 QNA/문의 최소 저장 구조. 관리자 답변 UI는 이번 범위에서 제외한다."
}

Table diet_records {
  id bigint [pk, increment]
  user_id bigint [not null, ref: > users.id]
  meal_type varchar(20)
  meal_time timestamptz
  description text
  image_path varchar(500)
  detected_foods jsonb
  nutrition_summary jsonb
  diet_score float
  diet_feedback text
  analysis_method varchar(30)
  is_user_corrected boolean [not null, default: false]
  memo text
  created_at timestamptz [not null]
  updated_at timestamptz [not null]

  indexes {
    (user_id)
    (user_id, meal_time)
    (analysis_method)
  }

  Note: "식단 기록 및 record-level 분석 결과. detected_foods는 화면 표시와 질환별 식단 점수 계산에 사용하는 결과이며, image_path는 storage backend local/S3의 private object key 또는 legacy local path를 저장한다."
}

Table diet_photo_results {
  id bigint [pk, increment]
  diet_record_id bigint [not null, ref: > diet_records.id]
  detected_foods jsonb
  confidence_payload jsonb
  raw_output jsonb
  is_dummy boolean [not null, default: true]
  created_at timestamptz [not null]

  indexes {
    (diet_record_id)
  }

  Note: "식단 사진 분석 provider/raw 결과 스냅샷. detected_foods는 provider가 반환한 원본 후보이며, 최종 화면/점수 기준은 diet_records.detected_foods를 우선한다."
}

Table medications {
  id bigint [pk, increment]
  user_id bigint [not null, ref: > users.id]
  name varchar(100) [not null]
  medication_type varchar(20) [not null]
  dosage varchar(100)
  frequency varchar(100)
  reminder_time time
  is_active boolean [not null, default: true]
  memo text
  created_at timestamptz [not null]
  updated_at timestamptz [not null]

  indexes {
    (user_id)
    (user_id, is_active)
    (medication_type)
  }

  Note: "복약/영양제 등록 최소 기능. 알림 예약/발송 이력은 reminder_schedules와 notification_logs에서 분리 관리한다."
}

Table medication_records {
  id bigint [pk, increment]
  medication_id bigint [not null, ref: > medications.id]
  user_id bigint [not null, ref: > users.id]
  scheduled_at timestamptz
  taken_at timestamptz
  is_taken boolean [not null, default: false]
  status varchar(30) [not null, default: 'PENDING']
  memo text
  created_at timestamptz [not null]
  updated_at timestamptz [not null]

  indexes {
    (medication_id)
    (user_id)
    (medication_id, scheduled_at)
    (user_id, scheduled_at)
  }

  Note: "복약/영양제 예정 및 복용 기록."
}

Table llm_generation_logs {
  id bigint [pk, increment]
  user_id bigint [ref: > users.id]
  target_type varchar(50)
  target_id bigint
  llm_task_type varchar(50) [not null]
  provider varchar(50)
  model_name varchar(100)
  prompt_version varchar(50)
  input_summary jsonb
  output_text text
  prompt_tokens int
  completion_tokens int
  total_tokens int
  estimated_cost decimal(12,6)
  status varchar(30) [not null, default: 'SUCCESS']
  error_message text
  latency_ms int
  created_at timestamptz [not null]

  indexes {
    (user_id)
    (target_type, target_id)
    (llm_task_type)
    (status)
  }

  Note: "LLM/설명 생성 결과 추적용 로그. prompt 원문 대신 요약 메타데이터 중심으로 저장한다."
}

Table system_error_logs {
  id bigint [pk, increment]
  request_id varchar(64)
  user_id bigint
  method varchar(10) [not null]
  path varchar(500) [not null]
  status_code int [not null]
  error_type varchar(100) [not null]
  error_message text
  stack_trace text
  client_ip varchar(100)
  user_agent varchar(500)
  created_at timestamptz [not null]

  indexes {
    (request_id)
    (user_id)
    (status_code)
    (created_at)
  }

  Note: "처리되지 않은 500 서버 예외 추적용 운영 로그. request body와 민감정보 원문은 저장하지 않는다. stack_trace는 운영환경에서 제한한다."
}

Table sensitive_access_logs {
  id bigint [pk, increment]
  request_id varchar(64)
  actor_user_id bigint [not null]
  actor_role varchar(30)
  target_user_id bigint [not null]
  action_type varchar(30) [not null]
  resource_type varchar(50) [not null]
  resource_id bigint
  access_reason varchar(255)
  method varchar(10) [not null]
  path varchar(500) [not null]
  client_ip varchar(100)
  user_agent varchar(500)
  created_at timestamptz [not null]

  indexes {
    (request_id)
    (actor_user_id)
    (target_user_id)
    (resource_type)
    (created_at)
  }

  Note: "건강정보, 분석결과, 검진표, 복약정보 등 민감정보 조회 접근 로그. 누가 어떤 리소스에 접근했는지만 저장하고 건강 수치/토큰/인증코드/원문 payload는 저장하지 않는다."
}
