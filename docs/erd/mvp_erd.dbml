// AI Healthcare MVP ERD
//
// 범위:
// - AUTH / USER
// - MAIN / MYPAGE
// - HEALTH
// - EXAM / OCR Dummy
// - ANALYSIS + SHAP
// - CHALLENGE
// - RAG 공식 문서/청크 메타데이터 관리
// - DASHBOARD 조회/집계
// - NOTIFICATION 최소기능
// - SETTINGS
// - QNA / FAQ
// - DIET 분석 더미/최소 기록
// - MEDICATION/SUPPLEMENT 최소 기록
// - LLM 더미/생성 로그
//
// 제외:
// - FAMILY
// - ADMIN
// - WEARABLE 연동
// - 운영 로그 상세
// - 외부 알림 SMS/Email/Push/Kakao
// - pgvector

Project ai_health_mvp {
  database_type: "PostgreSQL"
  Note: "FastAPI + AI Worker MVP schema. Dashboard와 MyPage는 별도 테이블 없이 관련 테이블을 조회/집계한다."
}

Enum gender {
  MALE
  FEMALE
}

Enum async_job_type {
  HEALTH_ANALYSIS
}

Enum async_job_status {
  PENDING
  RUNNING
  SUCCESS
  FAILED
  CANCELED
}

Enum analysis_type {
  DIABETES
  OBESITY
  DYSLIPIDEMIA
  HYPERTENSION
}

Enum ocr_status {
  PENDING
  PROCESSING
  SUCCESS
  FAILED
  CONFIRMED
}

Enum risk_level {
  LOW
  MEDIUM
  HIGH
}

Enum factor_direction {
  POSITIVE
  NEGATIVE
  NEUTRAL
}

Enum challenge_category {
  EXERCISE
  DIET
  SLEEP
  BLOOD_PRESSURE
  BLOOD_GLUCOSE
  WEIGHT
  HABIT
}

Enum challenge_status {
  ACTIVE
  INACTIVE
}

Enum user_challenge_status {
  JOINED
  COMPLETED
  CANCELED
}

Enum rag_disease_type {
  DIABETES
  OBESITY
  DYSLIPIDEMIA
  COMMON
}

Table users {
  id bigint [pk, increment]
  login_id varchar(40) [unique]
  email varchar(40) [not null, unique]
  hashed_password varchar(255) [not null]
  name varchar(20) [not null]
  nickname varchar(30)
  gender gender [not null]
  birthday date [not null]
  phone_number varchar(11) [not null, unique]
  address varchar(255)
  profile_image_url varchar(500)
  role varchar(20) [not null, default: 'USER']
  is_active boolean [not null, default: true]
  is_admin boolean [not null, default: false]
  last_login_at timestamptz
  failed_login_count int [not null, default: 0]
  locked_until timestamptz
  deactivated_at timestamptz
  email_verified_at timestamptz
  created_at timestamptz [not null]
  updated_at timestamptz [not null]

  Note: "AUTH / USER 기준 테이블. Firebase/소셜 로그인 전용 컬럼은 제거했고, 향후 소셜 로그인 재도입 시 별도 user_oauth_accounts 테이블을 권장한다. 권한 판단은 role 기준이며 is_admin은 legacy 호환 필드로 유지한다. 로그인 시각 표준은 last_login_at이다."
}

Table health_records {
  id bigint [pk, increment]
  user_id bigint [not null, ref: > users.id]
  height_cm decimal(5,2)
  weight_kg decimal(5,2)
  waist_cm decimal(5,2)
  bmi decimal(5,2)
  systolic_bp int
  diastolic_bp int
  fasting_glucose int
  hba1c decimal(4,2)
  total_cholesterol int
  ldl_cholesterol int
  hdl_cholesterol int
  triglyceride int
  has_diabetes boolean
  has_obesity boolean
  has_dyslipidemia boolean
  has_hypertension boolean
  occupation_code varchar(30)
  family_htn varchar(10)
  family_dm varchar(10)
  family_dyslipidemia varchar(10)
  smoking_status varchar(20)
  drinking_frequency varchar(30)
  drinking_amount varchar(30)
  walking_days_per_week int
  strength_days_per_week int
  is_smoker boolean
  drinks_alcohol boolean
  exercise_days_per_week int
  sleep_hours decimal(4,2)
  measured_at timestamptz [not null]
  created_at timestamptz [not null]
  updated_at timestamptz [not null]

  indexes {
    (user_id, measured_at)
  }

  Note: "사용자의 건강정보 입력 이력. x1 기본 분석 입력은 직업군/질병별 가족력/흡연/음주/걷기/근력운동을 포함하며, BMI는 신장/체중 기반 자동 계산값으로 저장한다. 교육수준/소득수준은 기본 필수 입력에서 제외한다."
}

Table exam_reports {
  id bigint [pk, increment]
  user_id bigint [not null, ref: > users.id]
  original_filename varchar(255) [not null]
  file_path varchar(500) [not null]
  exam_date date
  ocr_status ocr_status [not null, default: 'PENDING']
  is_confirmed boolean [not null, default: false]
  uploaded_at timestamptz [not null]
  confirmed_at timestamptz
  created_at timestamptz [not null]
  updated_at timestamptz [not null]

  indexes {
    (user_id, uploaded_at)
    (user_id, exam_date)
    (ocr_status)
  }

  Note: "건강검진표 업로드 파일과 OCR 처리 상태를 관리하는 MVP Dummy 테이블."
}

Table exam_measurements {
  id bigint [pk, increment]
  exam_report_id bigint [not null, ref: > exam_reports.id]
  measurement_key varchar(100) [not null]
  measurement_name varchar(100) [not null]
  value varchar(100)
  unit varchar(30)
  ocr_confidence decimal(5,4)
  is_user_confirmed boolean [not null, default: false]
  created_at timestamptz [not null]
  updated_at timestamptz [not null]

  indexes {
    (exam_report_id)
    (measurement_key)
  }

  Note: "OCR로 추출된 검진 수치 원본. 사용자 확인 전까지 value는 문자열로 보관한다."
}

Table async_jobs {
  id bigint [pk, increment]
  user_id bigint [not null, ref: > users.id]
  job_type async_job_type [not null]
  status async_job_status [not null, default: 'PENDING']
  target_table varchar(50)
  target_id bigint
  error_message text
  requested_at timestamptz [not null]
  started_at timestamptz
  finished_at timestamptz
  created_at timestamptz [not null]
  updated_at timestamptz [not null]

  indexes {
    (user_id, status)
    (job_type, status)
  }

  Note: "Backend가 생성하고 AI Worker가 처리 상태를 갱신하는 비동기 작업 테이블."
}

Table analysis_results {
  id bigint [pk, increment]
  user_id bigint [not null, ref: > users.id]
  health_record_id bigint [not null, ref: > health_records.id]
  // TODO: async_jobs 모델 및 FK 연동은 후속 PR에서 처리한다.
  async_job_id bigint [note: "Nullable BIGINT로 유지. async_jobs 모델/FK 연동은 후속 PR에서 처리한다."]
  analysis_type analysis_type [not null]
  risk_score decimal(6,5) [not null]
  risk_level risk_level [not null]
  summary varchar(255)
  model_name varchar(100)
  model_version varchar(50)
  analyzed_at timestamptz [not null]
  created_at timestamptz [not null]
  updated_at timestamptz [not null]

  indexes {
    (user_id, analyzed_at)
    (health_record_id, analysis_type)
  }

  Note: "당뇨/비만/이상지질혈증 위험도 분석 최종 결과."
}

Table analysis_result_factors {
  id bigint [pk, increment]
  analysis_result_id bigint [not null, ref: > analysis_results.id]
  factor_key varchar(100) [not null]
  factor_name varchar(100) [not null]
  factor_value varchar(100)
  contribution_score decimal(10,6)
  direction factor_direction [not null]
  display_order int [not null, default: 0]
  created_at timestamptz [not null]

  indexes {
    (analysis_result_id, display_order)
  }

  Note: "SHAP 또는 feature contribution 기반 주요 위험요인. factor_value는 float가 아니라 varchar로 유지한다."
}

Table analysis_snapshots {
  id bigint [pk, increment]
  analysis_result_id bigint [not null, ref: > analysis_results.id]
  input_payload jsonb [not null]
  output_payload jsonb [not null]
  shap_payload jsonb
  model_payload jsonb
  created_at timestamptz [not null]

  Note: "분석 재현과 디버깅을 위한 입력/출력/SHAP 원본 스냅샷."
}

Table challenges {
  id bigint [pk, increment]
  title varchar(100) [not null]
  description text
  category challenge_category [not null]
  target_metric varchar(100)
  target_value varchar(100)
  duration_days int [not null]
  status challenge_status [not null, default: 'ACTIVE']
  created_at timestamptz [not null]
  updated_at timestamptz [not null]

  indexes {
    (category, status)
  }

  Note: "MVP 챌린지 마스터 데이터."
}

Table user_challenges {
  id bigint [pk, increment]
  user_id bigint [not null, ref: > users.id]
  challenge_id bigint [not null, ref: > challenges.id]
  status user_challenge_status [not null, default: 'JOINED']
  started_at timestamptz [not null]
  completed_at timestamptz
  canceled_at timestamptz
  created_at timestamptz [not null]
  updated_at timestamptz [not null]

  indexes {
    (user_id, status)
    (challenge_id)
  }

  Note: "사용자 챌린지 참여/완료 상태."
}

Table challenge_logs {
  id bigint [pk, increment]
  user_challenge_id bigint [not null, ref: > user_challenges.id]
  log_date date [not null]
  is_completed boolean [not null, default: false]
  memo varchar(255)
  created_at timestamptz [not null]
  updated_at timestamptz [not null]

  indexes {
    (user_challenge_id, log_date)
  }

  Note: "사용자 챌린지 일별 수행 기록."
}

Table challenge_recommendations {
  id bigint [pk, increment]
  user_id bigint [not null, ref: > users.id]
  analysis_result_id bigint [not null, ref: > analysis_results.id]
  challenge_id bigint [not null, ref: > challenges.id]
  reason text
  priority int
  is_selected boolean [not null, default: false]
  created_at timestamptz [not null]
  updated_at timestamptz [not null]

  indexes {
    (user_id)
    (analysis_result_id)
    (challenge_id)
    (user_id, is_selected)
  }

  Note: "분석 결과와 주요 위험요인 기반 추천 챌린지."
}

Table rag_sources {
  id bigint [pk, increment]
  name varchar(100) [not null]
  organization varchar(100)
  source_type varchar(30) [not null]
  base_url varchar(500)
  description text
  is_active boolean [not null, default: true]
  created_at timestamptz [not null]
  updated_at timestamptz [not null]

  Note: "RAG 공식 근거 문서 출처 관리. pgvector embedding 컬럼은 후속 PR에서 추가한다."
}

Table rag_documents {
  id bigint [pk, increment]
  source_id bigint [not null, ref: > rag_sources.id]
  title varchar(255) [not null]
  disease_type rag_disease_type [not null]
  document_url varchar(500)
  published_at date
  fetched_at timestamptz
  version varchar(50)
  is_active boolean [not null, default: true]
  created_at timestamptz [not null]
  updated_at timestamptz [not null]

  indexes {
    (source_id)
    (disease_type, is_active)
  }

  Note: "RAG 공식 문서 메타데이터. 문서 원문/청크 검색 API는 이번 PR 범위에서 제외한다."
}

Table rag_chunks {
  id bigint [pk, increment]
  document_id bigint [not null, ref: > rag_documents.id]
  chunk_index int [not null]
  section_title varchar(255)
  content text [not null]
  disease_type rag_disease_type [not null]
  keywords text
  embedding_model varchar(100)
  created_at timestamptz [not null]
  updated_at timestamptz [not null]

  indexes {
    (document_id, chunk_index)
    (disease_type)
  }

  Note: "RAG 문서 chunk 메타데이터와 텍스트 본문. pgvector embedding 값은 아직 저장하지 않는다."
}

Table rag_retrieval_logs {
  id bigint [pk, increment]
  user_id bigint [ref: > users.id]
  analysis_result_id bigint [ref: > analysis_results.id]
  query_text text [not null]
  disease_type rag_disease_type
  retrieved_chunk_ids jsonb
  top_k int
  created_at timestamptz [not null]

  indexes {
    (user_id, created_at)
    (analysis_result_id)
  }

  Note: "향후 RAG 검색 결과 추적용 로그. 실제 검색 로직과 vector search는 이번 PR 범위에서 제외한다."
}

Table notifications {
  id bigint [pk, increment]
  user_id bigint [not null, ref: > users.id]
  notification_type varchar(30) [not null]
  title varchar(100) [not null]
  message text [not null]
  is_read boolean [not null, default: false]
  related_type varchar(50)
  related_id bigint
  read_at timestamptz
  created_at timestamptz [not null]
  updated_at timestamptz [not null]

  indexes {
    (user_id)
    (user_id, is_read)
    (notification_type)
  }

  Note: "웹 내부 알림 최소 기능. SMS/Email/Push/Kakao는 MVP 제외."
}

Table user_settings {
  id bigint [pk, increment]
  user_id bigint [not null, unique, ref: > users.id]
  notification_enabled boolean [not null, default: true]
  challenge_reminder_enabled boolean [not null, default: true]
  challenge_reminder_time time
  medication_reminder_enabled boolean [not null, default: true]
  diet_reminder_enabled boolean [not null, default: false]
  marketing_agreed boolean [not null, default: false]
  sensitive_data_agreed boolean [not null, default: false]
  created_at timestamptz [not null]
  updated_at timestamptz [not null]

  Note: "사용자별 알림/마케팅/민감정보 동의 설정. MyPage는 이 테이블과 사용자/건강정보 테이블을 조회해 구성한다."
}

Table faqs {
  id bigint [pk, increment]
  category varchar(50) [not null]
  question varchar(255) [not null]
  answer text [not null]
  display_order int [not null, default: 0]
  is_active boolean [not null, default: true]
  created_at timestamptz [not null]
  updated_at timestamptz [not null]

  indexes {
    (category)
    (is_active, display_order)
  }

  Note: "FAQ 최소 기능. 관리자 페이지는 이번 범위에서 제외한다."
}

Table inquiries {
  id bigint [pk, increment]
  user_id bigint [not null, ref: > users.id]
  category varchar(50) [not null]
  title varchar(255) [not null]
  content text [not null]
  status varchar(30) [not null, default: 'PENDING']
  answer text
  answered_at timestamptz
  created_at timestamptz [not null]
  updated_at timestamptz [not null]

  indexes {
    (user_id)
    (status)
    (category)
  }

  Note: "사용자 QNA/문의 최소 저장 구조. 관리자 답변 UI는 이번 범위에서 제외한다."
}

Table diet_records {
  id bigint [pk, increment]
  user_id bigint [not null, ref: > users.id]
  meal_type varchar(20)
  meal_time timestamptz
  description text
  image_path varchar(500)
  detected_foods jsonb
  nutrition_summary jsonb
  diet_score float
  diet_feedback text
  analysis_method varchar(30)
  is_user_corrected boolean [not null, default: false]
  memo text
  created_at timestamptz [not null]
  updated_at timestamptz [not null]

  indexes {
    (user_id)
    (user_id, meal_time)
    (analysis_method)
  }

  Note: "식단 기록 및 더미 분석 결과 저장. 실제 CV/ML 식단 분석 로직은 이번 범위에서 제외한다."
}

Table diet_photo_results {
  id bigint [pk, increment]
  diet_record_id bigint [not null, ref: > diet_records.id]
  detected_foods jsonb
  confidence_payload jsonb
  raw_output jsonb
  is_dummy boolean [not null, default: true]
  created_at timestamptz [not null]

  indexes {
    (diet_record_id)
  }

  Note: "식단 사진 분석 결과 원본 저장 구조. 실제 모델 추론은 이번 범위에서 제외한다."
}

Table medications {
  id bigint [pk, increment]
  user_id bigint [not null, ref: > users.id]
  name varchar(100) [not null]
  medication_type varchar(20) [not null]
  dosage varchar(100)
  frequency varchar(100)
  reminder_time time
  is_active boolean [not null, default: true]
  memo text
  created_at timestamptz [not null]
  updated_at timestamptz [not null]

  indexes {
    (user_id)
    (user_id, is_active)
    (medication_type)
  }

  Note: "복약/영양제 등록 최소 기능. 외부 알림 발송 로그는 이번 범위에서 제외한다."
}

Table medication_records {
  id bigint [pk, increment]
  medication_id bigint [not null, ref: > medications.id]
  user_id bigint [not null, ref: > users.id]
  scheduled_at timestamptz
  taken_at timestamptz
  is_taken boolean [not null, default: false]
  status varchar(30) [not null, default: 'PENDING']
  memo text
  created_at timestamptz [not null]
  updated_at timestamptz [not null]

  indexes {
    (medication_id)
    (user_id)
    (medication_id, scheduled_at)
    (user_id, scheduled_at)
  }

  Note: "복약/영양제 예정 및 복용 기록."
}

Table llm_generation_logs {
  id bigint [pk, increment]
  user_id bigint [ref: > users.id]
  target_type varchar(50)
  target_id bigint
  llm_task_type varchar(50) [not null]
  provider varchar(50)
  model_name varchar(100)
  prompt_version varchar(50)
  input_summary jsonb
  output_text text
  prompt_tokens int
  completion_tokens int
  total_tokens int
  estimated_cost decimal(12,6)
  status varchar(30) [not null, default: 'SUCCESS']
  error_message text
  latency_ms int
  created_at timestamptz [not null]

  indexes {
    (user_id)
    (target_type, target_id)
    (llm_task_type)
    (status)
  }

  Note: "LLM 더미/생성 결과 추적용 로그. 실제 LLM 호출 로직과 운영 모니터링 고도화는 이번 범위에서 제외한다."
}
