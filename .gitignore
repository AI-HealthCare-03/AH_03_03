"@
$content | Set-Content .gitignore -Encoding UTF8
var/

# KDU screening CatBoost staging package
!experiment/ml/kdu/screening/
!experiment/ml/kdu/screening/**

# Keep screening source/config/docs
!experiment/ml/kdu/screening/*.py
!experiment/ml/kdu/screening/*.json
!experiment/ml/kdu/screening/*.md

# Keep screening CatBoost runtime artifacts
!experiment/ml/kdu/screening/artifacts/
!experiment/ml/kdu/screening/artifacts/**/
!experiment/ml/kdu/screening/artifacts/**/model_fold*.cbm
!experiment/ml/kdu/screening/artifacts/**/feature_columns.json
!experiment/ml/kdu/screening/artifacts/**/threshold.json
!experiment/ml/kdu/screening/artifacts/**/metrics.json
!experiment/ml/kdu/screening/artifacts/**/model_params.json
!experiment/ml/kdu/screening/artifacts/**/experiment_config.json

# Keep optional screening verification reports
!experiment/ml/kdu/screening/artifact_verification_report.json

# Do not include large intermediate arrays unless explicitly needed
experiment/ml/kdu/screening/artifacts/**/*.npy
experiment/ml/kdu/screening/artifacts/**/oof_*.npy
experiment/ml/kdu/screening/artifacts/**/oof*.npy

# Local runtime/cache
var/

# KDU local experiment reports
