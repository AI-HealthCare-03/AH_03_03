ENV=local
SECRET_KEY=PLEASE_CHANGE_ME_FOR_LOCAL_ONLY

DB_HOST=postgres
DB_PORT=5432
DB_USER=ozcoding
DB_PASSWORD=pw1234
DB_NAME=ai_health

REDIS_HOST=redis
REDIS_PORT=6379

EMAIL_ENABLED=true
EMAIL_VERIFICATION_DEBUG=false
PASSWORD_RESET_DEBUG=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=AI HealthCare
SMTP_USE_TLS=true
FRONTEND_BASE_URL=http://localhost:8080

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
CHATBOT_USE_REAL_LLM=true
RAG_ENABLED=false

DIET_VISION_PROVIDER=gpt_vision
DIET_GPT_VISION_ENABLED=true
DIET_GPT_VISION_MODEL=gpt-4o-mini

# auto 정책: PDF는 PaddleOCR 우선, 이미지는 GPT Vision 우선.
EXAM_OCR_PROVIDER=auto
EXAM_GPT_VISION_ENABLED=true
EXAM_GPT_VISION_MODEL=gpt-4o-mini
PADDLE_OCR_ENABLED=true

MEDICATION_OCR_PROVIDER=gpt_vision
MEDICATION_GPT_VISION_ENABLED=true
MEDICATION_GPT_VISION_MODEL=gpt-4o-mini

LANGFUSE_ENABLED=false
LANGFUSE_BASE_URL=http://host.docker.internal:3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

STORAGE_BACKEND=local
LOCAL_STORAGE_ROOT=var/storage

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
VITE_FIREBASE_VAPID_KEY=
